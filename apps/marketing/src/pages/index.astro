<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="T3 Code (Gurt) — Code with Claude. An opinionated fork of T3 Code with full Claude Code support." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/png" href="/favicon-32x32.png" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon-16x16.png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>T3 Code (Gurt)</title>
  </head>
  <body>
    <div class="page">
      <nav class="nav">
        <a href="/" class="nav-brand">
          <img src="/icon.png" alt="T3" class="nav-icon" />
          <span class="nav-label">Gurt</span>
        </a>
        <div class="nav-right">
          <a
            href="https://github.com/DavidIlie/t3code"
            target="_blank"
            rel="noopener noreferrer"
            class="nav-link"
          >
            GitHub <span class="nav-arrow" aria-hidden="true">&#8599;</span>
          </a>
          <a
            href="https://github.com/pingdotgg/t3code"
            target="_blank"
            rel="noopener noreferrer"
            class="nav-link nav-link--dim"
          >
            Upstream
          </a>
        </div>
      </nav>

      <main class="main">
        <div class="hero">
          <div class="badge">
            <span class="badge-dot"></span>
            Claude Code + Codex
          </div>

          <h1 class="tagline">
            The best way to <span class="tagline-gradient">code with AI.</span>
          </h1>

          <p class="subtitle">
            An opinionated fork of <a href="https://github.com/pingdotgg/t3code" target="_blank" rel="noopener noreferrer" class="link">T3 Code</a> with
            full Claude Code support, performance improvements, and unsigned builds on every push.
            <br/>
            <span class="subtitle-author">by <a href="https://davidilie.com" target="_blank" rel="noopener noreferrer" class="link link--bright">David Ilie</a></span>
          </p>

          <div class="hero-actions">
            <a
              id="download-btn"
              href="https://github.com/DavidIlie/t3code/releases"
              class="btn btn--primary"
            >
              <svg class="btn-icon btn-icon--apple" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 814 1000" aria-hidden="true"><path fill="currentColor" d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105.6-57-155.5-127C46.7 790.7 0 663 0 541.8c0-194.4 126.4-297.5 250.8-297.5 66.1 0 121.2 43.4 162.7 43.4 39.5 0 101.1-46 176.3-46 28.5 0 130.9 2.6 198.3 99.2zm-234-181.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.3z"/></svg>
              <svg class="btn-icon btn-icon--windows" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 88 88" aria-hidden="true"><path fill="currentColor" d="m0 12.402 35.687-4.86.016 34.423-35.67.203zm35.67 33.529.028 34.453L.028 75.48.026 45.7zm4.326-39.025L87.314 0v41.527l-47.318.376zm47.329 39.349-.011 41.34-47.318-6.678-.066-34.739z"/></svg>
              <svg class="btn-icon btn-icon--linux" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 295" aria-hidden="true"><defs><linearGradient id="lt6" x1="49.984%" x2="49.984%" y1="89.845%" y2="40.632%"><stop offset="0%" stop-color="#FFEED7"/><stop offset="100%" stop-color="#BDBFC2"/></linearGradient><linearGradient id="lt8" x1="49.841%" x2="50.241%" y1="13.229%" y2="94.673%"><stop offset="0%" stop-color="#FFF" stop-opacity=".8"/><stop offset="100%" stop-color="#FFF" stop-opacity="0"/></linearGradient></defs><g fill="none"><path fill="#000" d="M63.213 215.474c-11.387-16.346-13.591-69.606 12.947-102.39C89.292 97.383 92.69 86.455 93.7 71.67c.734-16.805-11.846-66.851 35.537-70.616 48.027-3.857 45.364 43.526 45.088 68.596-.183 21.12 15.52 33.15 26.355 49.68 19.927 30.303 18.274 82.461-3.765 110.745-27.916 35.354-51.791 20.018-67.678 21.304-29.752 1.745-30.762 17.54-66.024-35.905"/><path fill="url(#lt6)" d="M81.027 145.684c6.52-14.785 20.386-40.772 20.662-60.883 0-15.978 47.843-19.835 51.7-3.856 3.856 15.978 13.59 39.853 19.834 51.424 6.245 11.478 24.335 48.118 5.051 80.074-17.356 28.284-69.973 50.69-98.073-3.856-9.55-18.917-7.806-42.333.826-62.903"/><path fill="url(#lt8)" d="M166.428 151.285c0 16.162-15.519 37.1-42.15 36.916-27.456.183-39.118-20.754-39.118-36.916 0-16.161 18.182-29.293 40.588-29.293 22.498.092 40.68 13.132 40.68 29.293"/></g></svg>
              <span id="download-label">Download now</span>
            </a>
            <a href="https://github.com/DavidIlie/t3code" target="_blank" rel="noopener noreferrer" class="btn btn--ghost">
              View source
            </a>
          </div>
        </div>

        <div class="screenshot-wrap">
          <img src="/screenshot-home.png" alt="T3 Code (Gurt) — Home" class="screenshot" />
        </div>

        <section class="features">
          <h2 class="section-title">Built for agents</h2>
          <div class="feature-grid">
            <div class="feature-card">
              <img src="/screenshot-project.png" alt="Project view with quick actions" class="feature-img" />
              <h3 class="feature-title">Project Dashboard</h3>
              <p class="feature-desc">Quick actions, recent threads, git integration, and multi-project management at a glance.</p>
            </div>
            <div class="feature-card">
              <img src="/screenshot-conversation.png" alt="Conversation with diff viewer" class="feature-img" />
              <h3 class="feature-title">Conversations & Diffs</h3>
              <p class="feature-desc">Chat with Claude Code or Codex and review code changes inline with the built-in diff viewer.</p>
            </div>
            <div class="feature-card feature-card--wide">
              <img src="/screenshot-terminal.png" alt="Integrated terminal" class="feature-img" />
              <h3 class="feature-title">Integrated Terminal</h3>
              <p class="feature-desc">Full terminal access within each project workspace. Split terminals, run commands, and watch your agent work.</p>
            </div>
          </div>
        </section>

        <section class="cta">
          <h2 class="cta-title">Ready to try it?</h2>
          <p class="cta-desc">Unsigned builds ship on every push. macOS, Windows, and Linux.</p>
          <a
            href="https://github.com/DavidIlie/t3code/releases"
            class="btn btn--primary btn--lg"
          >
            Download latest release
          </a>
        </section>
      </main>

      <footer class="footer">
        <span class="footer-copy">Opinionated by <a href="https://davidilie.com" target="_blank" rel="noopener noreferrer" class="footer-link">David Ilie</a></span>
        <div class="footer-links">
          <a href="https://github.com/DavidIlie/t3code" target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href="https://github.com/pingdotgg/t3code" target="_blank" rel="noopener noreferrer">Upstream</a>
        </div>
      </footer>
    </div>
  </body>
</html>

<script>
  const REPO = "DavidIlie/t3code";
  const RELEASES_URL = `https://github.com/${REPO}/releases`;
  const API_URL = `https://api.github.com/repos/${REPO}/releases/latest`;

  type Platform = { os: "mac" | "win" | "linux"; label: string; arch?: string };

  function detectPlatform(): Platform | null {
    const ua = navigator.userAgent;
    if (/Win/i.test(ua)) return { os: "win", label: "Download for Windows" };
    if (/Mac/i.test(ua)) return { os: "mac", label: "Download for macOS", arch: "arm64" };
    if (/Linux/i.test(ua)) return { os: "linux", label: "Download for Linux" };
    return null;
  }

  function pickAsset(
    assets: Array<{ name: string; browser_download_url: string }>,
    platform: Platform,
  ): string | null {
    if (platform.os === "win") {
      return assets.find((a) => a.name.endsWith("-x64.exe"))?.browser_download_url ?? null;
    }
    if (platform.os === "mac") {
      const preferred = assets.find((a) => a.name.endsWith(`-${platform.arch}.dmg`));
      const fallback = assets.find((a) => a.name.endsWith(".dmg"));
      return (preferred ?? fallback)?.browser_download_url ?? null;
    }
    if (platform.os === "linux") {
      return assets.find((a) => a.name.endsWith(".AppImage"))?.browser_download_url ?? null;
    }
    return null;
  }

  async function init() {
    const btn = document.getElementById("download-btn") as HTMLAnchorElement | null;
    const label = document.getElementById("download-label");
    if (!btn || !label) return;

    const platform = detectPlatform();
    if (!platform) return;

    document.documentElement.dataset.platform = platform.os;
    label.textContent = platform.label;

    try {
      const cached = sessionStorage.getItem("t3code-gurt-latest-release");
      const data = cached
        ? JSON.parse(cached)
        : await fetch(API_URL).then((r) => r.json());

      if (!cached && data?.assets) {
        sessionStorage.setItem("t3code-gurt-latest-release", JSON.stringify(data));
      }

      const url = pickAsset(data.assets ?? [], platform);
      if (url) {
        btn.href = url;
        btn.removeAttribute("target");
        btn.removeAttribute("rel");
      }
    } catch {
      btn.href = RELEASES_URL;
    }
  }

  init();
</script>

<style>
  :root {
    --bg: #09090b;
    --fg: #fafafa;
    --fg-muted: #a1a1aa;
    --fg-dim: #52525b;
    --border: rgba(255, 255, 255, 0.07);
    --accent: #d4a574;
    --accent-glow: rgba(212, 165, 116, 0.15);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { color-scheme: dark; }

  body {
    background: var(--bg);
    color: var(--fg);
    font-family: "DM Sans", -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
    overflow-x: hidden;
  }

  body::before {
    content: "";
    position: fixed;
    top: -40vh;
    left: 50%;
    transform: translateX(-50%);
    width: 120vw;
    height: 80vh;
    background: radial-gradient(ellipse at center, var(--accent-glow) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  body::after {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 256px 256px;
    z-index: 9999;
  }

  a { color: inherit; text-decoration: none; }
  img { display: block; max-width: 100%; }

  .page {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* ── Nav ── */

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 2.5rem;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .nav-icon { width: 28px; height: 28px; border-radius: 6px; }

  .nav-label {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    background: linear-gradient(135deg, var(--accent), #e8c9a0);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .nav-right { display: flex; gap: 1.25rem; align-items: center; }

  .nav-link {
    font-size: 0.85rem;
    color: var(--fg-muted);
    transition: color 0.2s;
  }

  .nav-link:hover { color: var(--fg); }
  .nav-link--dim { color: var(--fg-dim); }
  .nav-link--dim:hover { color: var(--fg-muted); }
  .nav-arrow { display: inline-block; transition: transform 0.2s; }
  .nav-link:hover .nav-arrow { transform: translate(1px, -1px); }

  /* ── Hero ── */

  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 8vh 1rem 4vh;
    text-align: center;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);
    background: color-mix(in srgb, var(--accent) 6%, transparent);
    padding: 0.35rem 0.9rem;
    border-radius: 999px;
    margin-bottom: 2rem;
    opacity: 0;
    animation: fade-in 0.8s ease-out forwards;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  .tagline {
    font-weight: 600;
    font-size: clamp(2.2rem, 5.5vw, 4rem);
    letter-spacing: -0.04em;
    line-height: 1.1;
    max-width: 700px;
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fade-in 0.8s ease-out 0.08s forwards;
  }

  .tagline-gradient {
    background: linear-gradient(135deg, var(--accent) 0%, #e8c9a0 50%, var(--fg) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    font-size: 1rem;
    color: var(--fg-muted);
    line-height: 1.7;
    max-width: 520px;
    margin-bottom: 2.5rem;
    opacity: 0;
    animation: fade-in 0.8s ease-out 0.16s forwards;
  }

  .subtitle-author { color: var(--fg-dim); }

  .link {
    color: var(--fg-muted);
    text-decoration: underline;
    text-decoration-color: rgba(255,255,255,0.15);
    text-underline-offset: 2px;
    transition: color 0.2s, text-decoration-color 0.2s;
  }

  .link:hover { color: var(--fg); text-decoration-color: var(--fg); }
  .link--bright { color: var(--accent); text-decoration-color: color-mix(in srgb, var(--accent) 30%, transparent); }
  .link--bright:hover { color: #e8c9a0; text-decoration-color: var(--accent); }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    margin-bottom: 5vh;
    opacity: 0;
    animation: fade-in 0.8s ease-out 0.24s forwards;
  }

  /* ── Buttons ── */

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.75rem;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.875rem;
    transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
  }

  .btn:hover { transform: scale(1.03); }
  .btn:active { transform: scale(0.98); }

  .btn--primary {
    background: var(--fg);
    color: var(--bg);
  }

  .btn--primary:hover {
    box-shadow: 0 0 32px rgba(255,255,255,0.1), 0 0 80px var(--accent-glow);
  }

  .btn--ghost {
    background: transparent;
    color: var(--fg-muted);
    border: 1px solid var(--border);
  }

  .btn--ghost:hover {
    background: rgba(255,255,255,0.04);
    color: var(--fg);
    border-color: rgba(255,255,255,0.15);
  }

  .btn--lg { padding: 0.85rem 2.25rem; font-size: 0.95rem; }

  .btn-icon { display: none; width: 1em; height: 1em; flex-shrink: 0; }
  :global([data-platform="mac"]) .btn-icon--apple { display: block; }
  :global([data-platform="win"]) .btn-icon--windows { display: block; }
  :global([data-platform="linux"]) .btn-icon--linux { display: block; }

  /* ── Screenshot ── */

  .screenshot-wrap {
    margin: 0 auto;
    width: min(92vw, 1300px);
    opacity: 0;
    transform: scale(0.97) translateY(12px);
    animation: screenshot-in 1s ease-out 0.3s forwards;
  }

  .screenshot {
    width: 100%;
    border-radius: 16px;
    border: 1px solid rgba(255,255,255,0.06);
    box-shadow: 0 40px 80px -20px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,255,255,0.03);
    mask-image: linear-gradient(to bottom, black 82%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 82%, transparent 100%);
  }

  /* ── Features ── */

  .features {
    width: min(92vw, 1100px);
    margin: 4rem auto;
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    text-align: center;
    margin-bottom: 2rem;
    color: var(--fg-muted);
    opacity: 0;
    animation: fade-in 0.8s ease-out 0.4s forwards;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .feature-card {
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1rem;
    background: rgba(255,255,255,0.015);
    backdrop-filter: blur(4px);
    transition: border-color 0.3s, background 0.3s;
    opacity: 0;
    animation: fade-in 0.8s ease-out 0.5s forwards;
  }

  .feature-card:hover {
    border-color: rgba(255,255,255,0.12);
    background: rgba(255,255,255,0.03);
  }

  .feature-card--wide { grid-column: 1 / -1; }

  .feature-img {
    width: 100%;
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.04);
    margin-bottom: 0.85rem;
  }

  .feature-title { font-size: 0.9rem; font-weight: 600; margin-bottom: 0.3rem; }
  .feature-desc { font-size: 0.8rem; color: var(--fg-muted); line-height: 1.55; }

  /* ── CTA ── */

  .cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 4rem 1rem 6rem;
    opacity: 0;
    animation: fade-in 0.8s ease-out 0.6s forwards;
  }

  .cta-title {
    font-size: 1.75rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .cta-desc {
    font-size: 0.9rem;
    color: var(--fg-muted);
    margin-bottom: 2rem;
  }

  /* ── Footer ── */

  .footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 2.5rem;
    font-size: 0.8rem;
    color: var(--fg-dim);
    border-top: 1px solid var(--border);
  }

  .footer-link {
    color: var(--fg-muted);
    text-decoration: underline;
    text-decoration-color: rgba(255,255,255,0.15);
    text-underline-offset: 2px;
    transition: color 0.2s;
  }

  .footer-link:hover { color: var(--fg); }
  .footer-links { display: flex; gap: 1.25rem; }
  .footer-links a { color: var(--fg-dim); transition: color 0.2s; }
  .footer-links a:hover { color: var(--fg); }

  /* ── Animations ── */

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes screenshot-in {
    from { opacity: 0; transform: scale(0.97) translateY(12px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* ── Mobile ── */

  @media (max-width: 640px) {
    .nav { padding: 1rem 1.25rem; }
    .hero { padding: 5vh 1rem 3vh; }
    .tagline { margin-bottom: 1rem; }
    .hero-actions { flex-direction: column; width: 100%; }
    .btn { width: 100%; justify-content: center; }
    .feature-grid { grid-template-columns: 1fr; }
    .footer { padding: 1.25rem; flex-direction: column; gap: 0.75rem; }
  }
</style>
