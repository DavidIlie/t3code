    <span id="download-label">Download now</span>
  </a>

  <a href="/download" class="other-platforms">Other platforms</a>

  <!-- macOS arch picker dialog -->
  <dialog id="mac-dialog" class="mac-dialog">
    <div class="mac-dialog-content">
      <h2 class="mac-dialog-title">Choose your Mac</h2>
      <p class="mac-dialog-desc">Not sure? Go to  &gt; About This Mac. Apple Silicon includes M1, M2, M3, and M4 chips.</p>
      <div class="mac-dialog-buttons">
        <a id="mac-arm64-btn" href="#" class="mac-dialog-btn">
          <span class="mac-dialog-btn-label">Apple Silicon</span>
          <span class="mac-dialog-btn-sub">M1, M2, M3, M4</span>
        </a>
        <a id="mac-x64-btn" href="#" class="mac-dialog-btn">
          <span class="mac-dialog-btn-label">Intel</span>
          <span class="mac-dialog-btn-sub">x86_64</span>
        </a>
      </div>
      <button id="mac-dialog-close" class="mac-dialog-close" type="button">&times;</button>
    </div>
  </dialog>

  <div class="screenshot-wrap">
    <img src="/screenshot-home.png" alt="T3 Gurt — Home" class="screenshot" />
  </div>

  <section class="features">
    <div class="feature-grid">
      <div class="feature-card">
        <img src="/screenshot-project.png" alt="Project view with quick actions" class="feature-img" />
        <h3 class="feature-title">Project Dashboard</h3>
        <p class="feature-desc">Quick actions, recent threads, git integration, and multi-project management at a glance.</p>
      </div>
      <div class="feature-card">
        <img src="/screenshot-conversation.png" alt="Conversation with diff viewer" class="feature-img" />
        <h3 class="feature-title">Conversations & Diffs</h3>
        <p class="feature-desc">Chat with Claude Code or Codex and review code changes inline with the built-in diff viewer.</p>
      </div>
      <div class="feature-card feature-card--wide">
        <img src="/screenshot-terminal.png" alt="Integrated terminal" class="feature-img" />
        <h3 class="feature-title">Integrated Terminal</h3>
        <p class="feature-desc">Full terminal access within each project workspace. Split terminals, run commands, and watch your agent work.</p>
      </div>
    </div>
  </section>

  <section class="usage-section">
    <div class="usage-grid">
      <div class="usage-text">
        <h2 class="usage-heading">Claude usage tracking, built in.</h2>
        <p class="usage-desc">See your Claude session and weekly usage at a glance. Rate limit tiers, reset times, and plan info — all in the sidebar without leaving your workspace.</p>
        <ul class="usage-list">
          <li>Session and weekly usage bars</li>
          <li>Rate limit reset countdown</li>
          <li>Works with Claude Max, Pro, and Team plans</li>
        </ul>
      </div>
      <div class="usage-screenshot-wrap">
        <img src="/screenshot-usage.png" alt="Claude usage stats in sidebar" class="usage-screenshot" />
      </div>
    </div>
  </section>

  <section class="why-gurt">
    <h2 class="why-gurt-heading">Why T3 Gurt?</h2>
    <p class="why-gurt-desc">Everything in T3 Code, plus:</p>
    <div class="why-gurt-grid">
      <div class="why-gurt-item">
        <span class="why-gurt-icon">&#9889;</span>
        <div>
          <h3 class="why-gurt-title">Full Claude Code support</h3>
          <p class="why-gurt-detail">First-class Claude Code adapter with image attachments, thinking mode, and the Claude Agent SDK.</p>
        </div>
      </div>
      <div class="why-gurt-item">
        <span class="why-gurt-icon">&#128202;</span>
        <div>
          <h3 class="why-gurt-title">Usage stats</h3>
          <p class="why-gurt-detail">Real-time Claude usage tracking with session, weekly, and daily tiers in the sidebar.</p>
        </div>
      </div>
      <div class="why-gurt-item">
        <span class="why-gurt-icon">&#128230;</span>
        <div>
          <h3 class="why-gurt-title">Clone from home page</h3>
          <p class="why-gurt-detail">Paste a git URL on the home screen and start working. Configurable working directory.</p>
        </div>
      </div>
      <div class="why-gurt-item">
        <span class="why-gurt-icon">&#128247;</span>
        <div>
          <h3 class="why-gurt-title">Image attachments for Claude</h3>
          <p class="why-gurt-detail">Paste screenshots and diagrams into the chat — they're sent as base64 image blocks to the Claude SDK.</p>
        </div>
      </div>
      <div class="why-gurt-item">
        <span class="why-gurt-icon">&#128736;</span>
        <div>
          <h3 class="why-gurt-title">Git history browser</h3>
          <p class="why-gurt-detail">Browse commits, view diffs, search by date — all from a built-in panel without leaving the app.</p>
        </div>
      </div>
      <div class="why-gurt-item">
        <span class="why-gurt-icon">&#128274;</span>
        <div>
          <h3 class="why-gurt-title">SVG upload protection</h3>
          <p class="why-gurt-detail">SVG files are blocked at upload to prevent XSS — a security fix not in the upstream.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="capabilities">
    <h2 class="capabilities-heading">Everything you need, built in.</h2>
    <div class="capabilities-grid">
      <div class="capability">
        <div class="capability-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v6m0 6v6m11-7h-6m-6 0H1m15.36-5.36l-4.24 4.24m-2.24-2.24L5.64 5.64m12.72 12.72l-4.24-4.24m-2.24 2.24l-4.24 4.24"/></svg>
        </div>
        <h3 class="capability-title">Command Palette</h3>
        <p class="capability-desc">Press <kbd>Cmd+K</kbd> to quickly navigate between projects, threads, and actions.</p>
      </div>
      <div class="capability">
        <div class="capability-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.855z"/></svg>
        </div>
        <h3 class="capability-title">Plan Mode</h3>
        <p class="capability-desc">Switch between chat and plan mode. Have your agent draft a plan before executing, with a dedicated sidebar to track progress.</p>
      </div>
      <div class="capability">
        <div class="capability-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <h3 class="capability-title">Supervised Mode</h3>
        <p class="capability-desc">Toggle between full-access and approval-required modes. Review and approve each action before the agent executes it.</p>
      </div>
      <div class="capability">
        <div class="capability-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65S8.93 17.38 9 18v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        </div>
        <h3 class="capability-title">Git History</h3>
        <p class="capability-desc">Browse commit history, view diffs for any commit, and manage branches — all without leaving the app.</p>
      </div>
      <div class="capability">
        <div class="capability-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" x2="12" y1="2" y2="15"/></svg>
        </div>
        <h3 class="capability-title">Commit, Push & PR</h3>
        <p class="capability-desc">Commit with AI-generated messages, push to remote, and create pull requests — one click from the toolbar.</p>
      </div>
      <div class="capability">
        <div class="capability-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M6 21V9a9 9 0 0 0 9 9"/></svg>
        </div>
        <h3 class="capability-title">Worktree Isolation</h3>
        <p class="capability-desc">Run each thread on its own git branch in an isolated worktree. Work on multiple tasks in parallel without conflicts.</p>
      </div>
      <div class="capability">
        <div class="capability-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        </div>
        <h3 class="capability-title">PR Review Threads</h3>
        <p class="capability-desc">Check out any pull request into a thread with full context. Review, discuss, and iterate on PRs inside the app.</p>
      </div>
      <div class="capability">
        <div class="capability-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="m9 12 2 2 4-4"/></svg>
        </div>
        <h3 class="capability-title">Project Scripts</h3>
        <p class="capability-desc">Define custom scripts per project with keyboard shortcuts. Run builds, tests, and linters from the toolbar.</p>
      </div>
      <div class="capability">
        <div class="capability-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/><path d="M12 7v5l3 3"/></svg>
        </div>
        <h3 class="capability-title">Checkpoints & Revert</h3>
        <p class="capability-desc">Every turn creates a checkpoint. View per-turn diffs and revert to any previous state if something goes wrong.</p>
      </div>
      <div class="capability">
        <div class="capability-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>
        </div>
        <h3 class="capability-title">Custom Keybindings</h3>
        <p class="capability-desc">Fully customizable keyboard shortcuts. Remap any action or add chord bindings to match your workflow.</p>
      </div>
      <div class="capability">
        <div class="capability-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
        </div>
        <h3 class="capability-title">Themes</h3>
        <p class="capability-desc">Light, dark, and system-aware themes. The terminal, diff viewer, and UI all follow your preference.</p>
      </div>
      <div class="capability">
        <div class="capability-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></svg>
        </div>
        <h3 class="capability-title">MCP Support</h3>
        <p class="capability-desc">Full Model Context Protocol integration. Connect external tools and data sources to your agent sessions.</p>
      </div>
      <div class="capability">
        <div class="capability-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
        </div>
        <h3 class="capability-title">Image Attachments</h3>
        <p class="capability-desc">Paste or drag images directly into the composer. Send screenshots, diagrams, and mockups to your agent.</p>
      </div>
      <div class="capability">
        <div class="capability-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
        </div>
        <h3 class="capability-title">Auto Updates</h3>
        <p class="capability-desc">Automatic update checks with one-click install. Always stay on the latest version without manual downloads.</p>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { fetchLatestRelease, RELEASES_URL, type ReleaseAsset } from "../lib/releases";

  type Platform = { os: "mac" | "win" | "linux"; label: string };

  function detectPlatform(): Platform | null {
    const ua = navigator.userAgent;
    if (/Win/i.test(ua)) return { os: "win", label: "Download for Windows" };
    if (/Mac/i.test(ua)) return { os: "mac", label: "Download for macOS" };
    if (/Linux/i.test(ua)) return { os: "linux", label: "Download for Linux" };
    return null;
  }

  function findAsset(assets: ReleaseAsset[], suffix: string): string | null {
    return assets.find((a) => a.name.endsWith(`-${suffix}`))?.browser_download_url ?? null;
  }

  async function init() {
    const btn = document.getElementById("download-btn") as HTMLAnchorElement | null;
    const label = document.getElementById("download-label");
    if (!btn || !label) return;

    const platform = detectPlatform();
    if (!platform) return;

    document.documentElement.dataset.platform = platform.os;
    label.textContent = platform.label;

    try {
      const release = await fetchLatestRelease();
      const assets = release.assets ?? [];

      if (platform.os === "mac") {
        // Show arch picker dialog on click instead of direct download
        const dialog = document.getElementById("mac-dialog") as HTMLDialogElement | null;
        const arm64Btn = document.getElementById("mac-arm64-btn") as HTMLAnchorElement | null;
        const x64Btn = document.getElementById("mac-x64-btn") as HTMLAnchorElement | null;
        const closeBtn = document.getElementById("mac-dialog-close");

        if (dialog && arm64Btn && x64Btn) {
          arm64Btn.href = findAsset(assets, "arm64.dmg") ?? RELEASES_URL;
          x64Btn.href = findAsset(assets, "x64.dmg") ?? RELEASES_URL;

          btn.addEventListener("click", (e) => {
            e.preventDefault();
            dialog.showModal();
          });

          closeBtn?.addEventListener("click", () => dialog.close());
          dialog.addEventListener("click", (e) => {
            if (e.target === dialog) dialog.close();
          });
        }
      } else if (platform.os === "win") {
        const url = findAsset(assets, "x64.exe");
        if (url) {
          btn.href = url;
          btn.removeAttribute("target");
          btn.removeAttribute("rel");
        }
      } else if (platform.os === "linux") {
        const url = findAsset(assets, "x86_64.AppImage");
        if (url) {
          btn.href = url;
          btn.removeAttribute("target");
          btn.removeAttribute("rel");
        }
      }
    } catch {
      btn.href = RELEASES_URL;
    }
  }

  init();
</script>

